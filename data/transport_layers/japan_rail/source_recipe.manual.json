{
  "version": "japan_rail_sources_v1",
  "family": "rail",
  "country": "Japan",
  "generated_policy": "manual_source_cache_only",
  "notes": [
    "Source files stay in .runtime/source-cache and are not committed into the repository.",
    "Builds must fail clearly when the official N02 line or station source is missing or cannot be decoded.",
    "OSM lifecycle patches and class / major-station override files are optional inputs. Missing optional inputs must be reported in build_audit.json instead of being guessed silently."
  ],
  "encoding_policy": {
    "display_fields_encoding": "utf-8",
    "source_fallback_encoding": "cp932",
    "match_key_normalization": "NFKC",
    "display_fields_preserve_original_text": true
  },
  "sources": [
    {
      "id": "mlit_n02_2024_lines",
      "kind": "download",
      "role": "geometry_primary",
      "url": "https://nlftp.mlit.go.jp/ksj/gml/data/N02/N02-24/N02-24_GML.zip",
      "expected_filename": "N02-24_GML.zip",
      "preferred_member": "UTF-8/N02-24_RailroadSection.geojson",
      "fallback_member": "N02-24_RailroadSection.shp",
      "license": "MLIT open data terms",
      "ingest_mode": "local_file",
      "encoding": "UTF-8 preferred, CP932 fallback",
      "field_contract": {
        "rail_type_code": "N02_001",
        "operator_type_code": "N02_002",
        "line_name": "N02_003",
        "operator": "N02_004"
      }
    },
    {
      "id": "mlit_n02_2024_stations",
      "kind": "download",
      "role": "station_primary",
      "url": "https://nlftp.mlit.go.jp/ksj/gml/data/N02/N02-24/N02-24_GML.zip",
      "expected_filename": "N02-24_GML.zip",
      "preferred_member": "UTF-8/N02-24_Station.geojson",
      "fallback_member": "N02-24_Station.shp",
      "license": "MLIT open data terms",
      "ingest_mode": "local_file",
      "encoding": "UTF-8 preferred, CP932 fallback",
      "field_contract": {
        "line_name": "N02_003",
        "operator": "N02_004",
        "station_name": "N02_005",
        "station_code": "N02_005c",
        "group_code": "N02_005g"
      }
    },
    {
      "id": "osm_japan_lifecycle_patch",
      "kind": "local_prepared_geojson",
      "role": "status_patch_optional",
      "optional": true,
      "expected_filename": "osm_lifecycle_lines.geojson",
      "license": "ODbL 1.0"
    },
    {
      "id": "line_class_overrides",
      "kind": "local_manual_json",
      "role": "classification_override_optional",
      "optional": true,
      "expected_filename": "line_class_overrides.json"
    },
    {
      "id": "major_station_overrides",
      "kind": "local_manual_json",
      "role": "station_selection_override_optional",
      "optional": true,
      "expected_filename": "major_station_overrides.json"
    }
  ],
  "output_contract": {
    "publish": [
      "railways.topo.json",
      "rail_stations_major.geojson",
      "railways.preview.topo.json",
      "rail_stations_major.preview.geojson",
      "manifest.json",
      "build_audit.json"
    ],
    "runtime_consumer": "transport_workbench_rail_preview",
    "adapter_id": "japan_rail_v1"
  }
}
