{
  "name": "scenario-forge-browser-tooling",
  "private": true,
  "version": "0.1.0",
  "description": "Local Playwright tooling for Scenario Forge browser inspection and e2e regression tests.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:transport-workbench-carrier": "python tools/build_transport_workbench_japan_carrier.py",
    "build:transport-workbench-japan-roads": "python tools/build_transport_workbench_japan_roads.py",
    "build:transport-workbench-japan-rail": "python tools/build_transport_workbench_japan_rail.py",
    "build:transport-workbench-japan-airports": "python tools/build_transport_workbench_japan_airports.py",
    "build:transport-workbench-japan-ports": "python tools/build_transport_workbench_japan_ports.py",
    "playwright:install": "playwright install",
    "playwright:install:chromium": "playwright install --with-deps chromium",
    "verify:ui-contract-foundation": "python -m unittest tests/test_ui_rework_plan01_foundation_contract.py",
    "verify:ui-rework-mainline": "python -m unittest tests/test_ui_rework_plan02_mainline_contract.py",
    "verify:ui-rework-support": "python -m unittest tests/test_ui_rework_plan03_support_transport_contract.py",
    "verify:scenario-contracts": "python tools/check_scenario_contracts.py --scenario-dir data/scenarios/tno_1962",
    "verify:scenario-contracts:strict": "python tools/check_scenario_contracts.py --strict --scenario-dir data/scenarios/tno_1962 --report-path .runtime/reports/generated/tno_1962.strict_contract_report.json",
    "perf:baseline": "node tools/perf/run_baseline.mjs --mode baseline",
    "perf:gate": "node tools/perf/run_baseline.mjs --mode gate --scenarios blank_base,tno_1962 --runs 3 --warmups 1 --threshold 1.15 --write-markdown false",
    "test:e2e:ui-contract-foundation": "node node_modules/@playwright/test/cli.js test tests/e2e/ui_contract_foundation.spec.js --reporter=list --workers=1 --retries=0",
    "test:e2e:ui-rework-mainline": "node node_modules/@playwright/test/cli.js test tests/e2e/ui_rework_mainline_shell_sidebar.spec.js --reporter=list --workers=1 --retries=0",
    "test:e2e:ui-rework-support": "node node_modules/@playwright/test/cli.js test tests/e2e/ui_rework_support_transport_hardening.spec.js --reporter=list --workers=1 --retries=0",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "test:node:renderer-splits": "node --test tests/strategic_overlay_runtime_owner_behavior.test.mjs tests/strategic_overlay_state_behavior.test.mjs",
    "test:e2e:smoke": "node node_modules/@playwright/test/cli.js test tests/e2e/main_shell_i18n.spec.js tests/e2e/scenario_apply_resilience.spec.js --reporter=list --workers=1",
    "test:e2e:strategic-overlay-smoke": "node node_modules/@playwright/test/cli.js test tests/e2e/strategic_overlay_smoke.spec.js --reporter=list --workers=1 --retries=0",
    "test:e2e:project-save-load": "node node_modules/@playwright/test/cli.js test tests/e2e/project_save_load_roundtrip.spec.js --reporter=list --workers=1",
    "test:e2e:interaction-funnel": "node node_modules/@playwright/test/cli.js test tests/e2e/interaction_funnel_contract.spec.js --reporter=list --workers=1 --retries=0",
    "test:e2e:scenario-resilience": "node node_modules/@playwright/test/cli.js test tests/e2e/scenario_apply_resilience.spec.js --reporter=list --workers=1",
    "verify:pages-dist": "python tools/build_pages_dist.py && python -m unittest tests.test_pages_dist_startup_shell -q",
    "build:global-transport-roads": "python tools/build_global_transport_roads.py",
    "build:global-transport-rail": "python tools/build_global_transport_rail.py",
    "build:global-transport-road-catalog": "python tools/build_global_transport_catalogs.py --family road"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "playwright": "1.58.2"
  }
}
