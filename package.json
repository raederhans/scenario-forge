{
  "name": "mapcreator-browser-tooling",
  "private": true,
  "version": "0.1.0",
  "description": "Local Playwright tooling for mapcreator browser inspection and e2e regression tests.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "playwright:install": "playwright install",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "test:e2e:project-save-load": "node node_modules/@playwright/test/cli.js test tests/e2e/project_save_load_roundtrip.spec.js --reporter=list --workers=1",
    "test:e2e:scenario-resilience": "node node_modules/@playwright/test/cli.js test tests/e2e/scenario_apply_resilience.spec.js --reporter=list --workers=1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "playwright": "1.58.2"
  }
}
